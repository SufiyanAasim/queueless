# ============================================================================
# QueueLess Backend - Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- JWT (admin authentication) ---
# Use a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_64_byte_random_hex_string
JWT_EXPIRES_IN=8h

# --- Admin bootstrap account ---
# Set on first deploy. Backend will create this account if it doesn't exist
# in Firebase. Password is bcrypt-hashed before storage.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_deploy

# --- Firebase Admin SDK ---
# Get these from Firebase console > Project Settings > Service Accounts >
# Generate new private key. Paste the values from the downloaded JSON.
# The PRIVATE_KEY must keep its \n escape sequences - the code unescapes them.
FIREBASE_PROJECT_ID=queueless-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@queueless-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://queueless-xxxxx-default-rtdb.firebaseio.com

# --- Queue tuning ---
# Average service time per token in seconds. Used for ETA calculations.
AVG_SERVICE_TIME_SECONDS=180
# Token expires automatically if unserved after this many seconds.
TOKEN_EXPIRY_SECONDS=3600

# --- Analytics dual-write (Data Mining project bridge) ---
# Every queue event is also written to a flat log for the DM pipeline.
# Set ANALYTICS_SINK to "csv" (default) or "mongo".
ANALYTICS_SINK=csv
ANALYTICS_CSV_PATH=../analytics/data/queue_events.csv

# Only required if ANALYTICS_SINK=mongo
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/queueless
MONGO_DB=queueless
MONGO_COLLECTION=queue_events
