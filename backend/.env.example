# QueueLess Backend - Environment Variables
# Copy to .env and fill in real values. Never commit .env.

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_64_byte_random_hex_string
JWT_EXPIRES_IN=8h

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_deploy

# Firebase console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=queueless-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@queueless-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://queueless-xxxxx-default-rtdb.firebaseio.com

AVG_SERVICE_TIME_SECONDS=180
TOKEN_EXPIRY_SECONDS=3600

ANALYTICS_SINK=csv
ANALYTICS_CSV_PATH=../analytics/data/queue_events.csv
# Trained ML artefact (predictions.json) consumed by the prediction service.
# Falls back to backend/models/predictions.json, then to rule-based heuristics.
ANALYTICS_MODEL_PATH=../analytics/models/predictions.json

# Required if ANALYTICS_SINK=mongo
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/queueless
MONGO_DB=queueless
MONGO_COLLECTION=queue_events
# Full per-token lifecycle mirror collection (v1.4.0+)
MONGO_TOKENS_COLLECTION=tokens

# Email (optional - leave SMTP_HOST blank to disable token emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com

# Frontend URL for token tracking links in emails
FRONTEND_URL=http://localhost:5173

# AI assistant (optional). Defaults to the zero-config "grounded" provider that
# answers deterministically from verified data with NO external API or key.
# To use an LLM, set AI_PROVIDER and AI_API_KEY (free options: groq, gemini, ollama).
AI_PROVIDER=grounded
# AI_PROVIDER=groq
# AI_API_KEY=your_api_key_here
# AI_MODEL=llama-3.1-8b-instant
# AI_BASE_URL=   # override only for self-hosted / custom OpenAI-compatible endpoints
