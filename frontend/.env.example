# --------------------------------------------------------------------------
# QueueLess Frontend Environment
# Copy to `.env.local`. Variables prefixed with VITE_ are exposed to the
# browser - only put PUBLIC values here. Firebase web-config keys ARE public
# by design (security is enforced by Realtime DB rules, not by hiding the key).
# --------------------------------------------------------------------------

VITE_API_BASE_URL=http://localhost:4000/api/v1

# Firebase web config - copy from Firebase console > Project Settings > General > Your apps > Web app.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=queueless-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=queueless-xxxxx
VITE_FIREBASE_DATABASE_URL=https://queueless-xxxxx-default-rtdb.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=queueless-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef
