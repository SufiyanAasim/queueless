# Environment files (NEVER commit real secrets)
.env
.env.local
.env.*.local
*.env
!*.env.example

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/cache
.yarn/install-state.gz

# Build outputs
dist/
build/
.next/
.vite/
.turbo/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/
ENV/

