analytics/data/queue_events.csv
analytics/data/tokens_processed.csv
analytics/data/charts/
analytics/models/*.joblib

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
*.swp
*.swo

# Logs
logs/
*.log

# Firebase Admin SDK Secrets
*firebase-adminsdk*.json
